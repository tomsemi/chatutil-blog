---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, getAllTags, getNotes, getReadingMinutes } from "../../lib/notes";

export async function getStaticPaths() {
  const notes = await getNotes();
  return getAllTags(notes).map(({ tag }) => ({
    params: { tag },
    props: {
      tag,
      notes: notes.filter((note) => note.data.tags.includes(tag)),
    },
  }));
}

const { tag, notes } = Astro.props;
---

<BaseLayout title={`Tag: ${tag}`} description={`Notes tagged ${tag}.`}>
  <main class="site-shell">
    <section class="intro">
      <div>
        <p class="eyebrow">Tag</p>
        <h1>{tag}</h1>
        <p class="intro-copy">{notes.length} 篇相关笔记。</p>
      </div>
    </section>

    <section class="note-list" aria-label={`Notes tagged ${tag}`}>
      {notes.map((note) => (
        <a class="note-card" href={`/notes/${note.slug}/`}>
          <div class="note-meta">
            <div>{formatDate(note.data.date)}</div>
            <div>{getReadingMinutes(note.body)} min read</div>
          </div>
          <article>
            <h2>{note.data.title}</h2>
            <p>{note.data.description}</p>
          </article>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>
